{
  "name": "mcp-file-upload-sample",
  "version": "0.1.0",
  "private": true,
  "description": "Sample MCP + HTTP file upload backend with MinIO (S3-compatible)",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js --stdio",
    "mcp:stdio:shell": "bash scripts/run-mcp-stdio.sh",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.5",
    "prettier": "^3.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "resolutions": {
    "@types/express": "4.17.21",
    "@types/express-serve-static-core": "4.19.6"
  }
}
